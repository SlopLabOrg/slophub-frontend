---
import { DetailApp } from "../App.jsx";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  appCanonicalPath,
  appImage,
  appJsonLd,
  fetchSlophubData,
} from "../lib/slophub.js";

export async function getStaticPaths() {
  const data = await fetchSlophubData();

  return data.apps.map((app) => ({
    params: {
      appId: app.app_id,
    },
    props: {
      app,
      remote: data.remote,
      generatedAt: data.generatedAt,
    },
  }));
}

const { app, remote, generatedAt } = Astro.props;
const canonicalPath = appCanonicalPath(app);
const basePath = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
const canonicalUrl = new URL(`${basePath}${canonicalPath}`, Astro.site ?? Astro.url).toString();
const title = `${app.title} - Slophub`;
const description = app.description || `Install ${app.title} from Slophub.`;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  image={appImage(app)}
  jsonLd={appJsonLd(app, canonicalUrl)}
>
  <DetailApp client:load app={app} remote={remote} generatedAt={generatedAt} />
</BaseLayout>
